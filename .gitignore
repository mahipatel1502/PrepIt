# 🔒 PrepIt Root .gitignore
# This ensures security even if subfolders are committed

# Environment files - CRITICAL
.env
.env.local
.env*.local
.env.production
.env.development
*.env

# Firebase credentials - CRITICAL: Never commit!
*firebase*.json
firebase-credentials.json
firebase-service-account*.json
prepit-*.json

# Python
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
venv/
env/
ENV/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next/
out/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
.DS_Store
desktop.ini

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
*.cache

# Security
*.pem
*.key
*.cert
*.crt
